      ],
      "sentences": [
        {
          "index": 0,
          "text": "Excuse me, I am looking for the main train station right now.",
          "translationJa": "すみません、今中央駅を探しています。",
          "id": "beginner-2026-07-04-s01",
          "startMs": 0,
          "endMs": 3711,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-07-04/beginner-s01.m4a"
        },
        {
          "index": 1,
          "text": "Could you please tell me how to get to that place?",
          "translationJa": "そこへ行く方法を教えていただけますか？",
          "id": "beginner-2026-07-04-s02",
          "startMs": 4111,
          "endMs": 6536,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-07-04/beginner-s02.m4a"
        },
        {
          "index": 2,
          "text": "I am a bit lost because this city is very big today.",
          "translationJa": "この街はとても大きいので、少し迷っています。",
          "id": "beginner-2026-07-04-s03",
          "startMs": 6936,
          "endMs": 9846,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-07-04/beginner-s03.m4a"
        },
        {
          "index": 3,
          "text": "Is it far from here to walk to the city center?",
          "translationJa": "ここから市内中心部まで歩くのは遠いですか？",
          "id": "beginner-2026-07-04-s04",
          "startMs": 10246,
          "endMs": 12623,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-07-04/beginner-s04.m4a"
        },
        {
          "index": 4,
          "text": "Please go straight until you see a big blue building there.",
          "translationJa": "あそこに大きな青い建物が見えるまで真っ直ぐ進んでください。",
          "id": "beginner-2026-07-04-s05",
          "startMs": 13023,
          "endMs": 15773,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-07-04/beginner-s05.m4a"
        },
        {
          "index": 5,
          "text": "Then you should turn left at the next small street corner.",
          "translationJa": "それから次の小さな角を左に曲がってください。",
          "id": "beginner-2026-07-04-s06",
          "startMs": 16173,
          "endMs": 18946,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-07-04/beginner-s06.m4a"
        },
        {
          "index": 6,
          "text": "The station will be on your right side after the park.",
          "translationJa": "駅は公園を過ぎた右側にあります。",
          "id": "beginner-2026-07-04-s07",
          "startMs": 19346,
          "endMs": 22063,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-07-04/beginner-s07.m4a"
        },
        {
          "index": 7,
          "text": "Thank you very much for your kind help with my trip.",
          "translationJa": "旅行の助けをいただき、本当にありがとうございます。",
          "id": "beginner-2026-07-04-s08",
          "startMs": 22463,
          "endMs": 25204,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-07-04/beginner-s08.m4a"
        },
        {
          "index": 8,
          "text": "I hope you have a wonderful day in this beautiful city.",
          "translationJa": "あなたもこの美しい街で素敵な一日を過ごしてくださいね。",
          "id": "beginner-2026-07-04-s09",
          "startMs": 25604,
          "endMs": 28282,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-07-04/beginner-s09.m4a"
        }
      ],
