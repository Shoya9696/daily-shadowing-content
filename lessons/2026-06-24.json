      "audioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/advanced.m4a",
      "durationSeconds": 21,
      "sentences": [
        {
          "id": "advanced-2026-06-24-s01",
          "index": 0,
          "text": "Workplace wellness guidance increasingly emphasizes micro-breaks rather than long idle periods.",
          "translationJa": "職場の健康づくりの指針は、長い中断よりも短いマイクロブレイクを重視するようになっています。",
          "startMs": 0,
          "endMs": 5505,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/advanced-s01.m4a"
        },
        {
          "id": "advanced-2026-06-24-s02",
          "index": 1,
          "text": "Brief movement and hydration can interrupt mental fatigue without breaking workflow momentum.",
          "translationJa": "短い運動と水分補給は、作業の流れを大きく途切れさせずに精神的な疲れを中断できます。",
          "startMs": 5905,
          "endMs": 10786,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/advanced-s02.m4a"
        },
        {
          "id": "advanced-2026-06-24-s03",
          "index": 2,
          "text": "Employees who plan short resets often report steadier concentration across the afternoon.",
          "translationJa": "短いリセットを計画する従業員は、午後の集中力が安定しやすいと答えることが多いです。",
          "startMs": 11186,
          "endMs": 16488,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/advanced-s03.m4a"
        },
        {
          "id": "advanced-2026-06-24-s04",
          "index": 3,
          "text": "The key is consistency, not intensity, when building sustainable focus habits.",
          "translationJa": "持続可能な集中の習慣を作るうえで大切なのは強度ではなく一貫性です。",
          "startMs": 16888,
          "endMs": 21881,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/advanced-s04.m4a"
        }
