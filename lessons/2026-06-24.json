      "audioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/intermediate.m4a",
      "durationSeconds": 14,
      "sentences": [
        {
          "id": "intermediate-2026-06-24-s01",
          "index": 0,
          "text": "Many office workers schedule short breaks to reset their focus.",
          "translationJa": "多くの会社員は集中力をリセットするために短い休憩を入れます。",
          "startMs": 0,
          "endMs": 3441,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/intermediate-s01.m4a"
        },
        {
          "id": "intermediate-2026-06-24-s02",
          "index": 1,
          "text": "A five-minute walk can reduce eye strain from long screen time.",
          "translationJa": "5分歩くだけで、長時間の画面作業による目の疲れを和らげられます。",
          "startMs": 3841,
          "endMs": 7135,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/intermediate-s02.m4a"
        },
        {
          "id": "intermediate-2026-06-24-s03",
          "index": 2,
          "text": "Hydration and light stretching also support steady productivity.",
          "translationJa": "水分補給と軽いストレッチも安定した生産性を支えます。",
          "startMs": 7535,
          "endMs": 11154,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/intermediate-s03.m4a"
        },
        {
          "id": "intermediate-2026-06-24-s04",
          "index": 3,
          "text": "Small habits like these are easy to repeat every day.",
          "translationJa": "こうした小さな習慣は毎日続けやすいです。",
          "startMs": 11554,
          "endMs": 14435,
          "sentenceAudioUrl": "https://shoya9696.github.io/daily-shadowing-content/audio/2026-06-24/intermediate-s04.m4a"
