    {
      "id": "advanced-2026-06-24",
      "levelGroup": "advanced",
      "title": "Micro-breaks and Sustainable Focus",
      "cefrLevel": "B2",
      "summaryJa": "マイクロブレイクと持続可能な集中について扱います。",
      "sourceUrls": [
        "https://www.cdc.gov/workplacehealthpromotion/index.html"
